<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.common.auth.ResetPasswordController"
           prefWidth="900.0" prefHeight="700.0"
           style="-fx-background-color: linear-gradient(to bottom right, #f8fafc, #e2e8f0);">

    <children>
        <VBox alignment="CENTER" spacing="16" maxWidth="460"
              style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 35;"
              StackPane.alignment="CENTER">
            <children>
                <Label text="Changer le mot de passe">
                    <font>
                        <Font name="Segoe UI Bold" size="24"/>
                    </font>
                </Label>

                <Label fx:id="emailLabel" text="-" style="-fx-text-fill: #64748b; -fx-font-size: 13;"/>

                <PasswordField fx:id="newPasswordField" promptText="Nouveau mot de passe" prefHeight="44"
                               style="-fx-font-size: 14; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #cbd5e1;"/>

                <PasswordField fx:id="confirmPasswordField" promptText="Confirmer le mot de passe" prefHeight="44"
                               style="-fx-font-size: 14; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #cbd5e1;"/>

                <HBox alignment="CENTER" spacing="10">
                    <children>
                        <Button fx:id="saveBtn" text="Enregistrer" prefWidth="130" prefHeight="42"
                                style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: linear-gradient(to right, #d4af37, #c9920f); -fx-background-radius: 10;"/>
                        <Button fx:id="cancelBtn" text="Annuler" prefWidth="130" prefHeight="42"
                                style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-background-color: #e2e8f0; -fx-background-radius: 10;"/>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets top="8" right="8" bottom="8" left="8"/>
            </padding>
        </VBox>
    </children>
</StackPane>
