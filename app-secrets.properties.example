# Copie ce fichier en: app-secrets.properties (NE PAS COMMIT)
# Puis remplis tes valeurs.
#
# SMTP (Email)
# Mailtrap (Sandbox) — reprends exactement host/port/user/pass depuis l'UI Mailtrap.
APP_SMTP_HOST=sandbox.smtp.mailtrap.io
APP_SMTP_PORT=587
APP_SMTP_USER=your_mailtrap_username
APP_SMTP_PASS=your_mailtrap_password
APP_EMAIL_FROM=no-reply@fin-tokhrej.tn
# Debug JavaMail (optionnel)
APP_SMTP_DEBUG=false

# Gmail (optionnel)
# - Active la validation en 2 étapes sur ton compte Google
# - Génère un "mot de passe d'application" et utilise-le dans APP_SMTP_PASS
# - Ne mets jamais ton mot de passe Google ici
# APP_SMTP_HOST=smtp.gmail.com
# APP_SMTP_PORT=587
# APP_SMTP_USER=youraddress@gmail.com
# APP_SMTP_PASS=your_app_password
# APP_EMAIL_FROM=youraddress@gmail.com
# APP_SMTP_DEBUG=false

# Twilio (SMS) - optionnel
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
