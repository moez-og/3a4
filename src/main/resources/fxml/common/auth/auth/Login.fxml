<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:id="root"
           fx:controller="controllers.common.auth.LoginController"
           prefWidth="900.0" prefHeight="700.0">

    <children>
        <ImageView fx:id="bgImage" preserveRatio="false" smooth="true" fitWidth="900.0" fitHeight="700.0">
            <image>
                <Image url="@/images/logo/bg.png"/>
            </image>
        </ImageView>

        <HBox prefWidth="900.0" prefHeight="700.0" alignment="CENTER" spacing="50">
            <padding>
                <Insets top="35" right="45" bottom="35" left="45"/>
            </padding>

            <children>
                <VBox alignment="CENTER_LEFT" spacing="12" prefWidth="390">
                    <children>
                        <ImageView fitWidth="140" preserveRatio="true">
                            <image>
                                <Image url="@/images/logo/logo.png"/>
                            </image>
                        </ImageView>

                        <Label text="EXPLORE&#10;HORIZONS" textFill="white">
                            <font>
                                <Font name="Segoe UI Black" size="58"/>
                            </font>
                        </Label>

                        <Label text="Where Your Dream Destinations&#10;Become Reality"
                               textFill="white"
                               style="-fx-font-size: 24; -fx-font-family: 'Segoe UI Semibold'; -fx-line-spacing: 4;"
                               wrapText="true"/>

                        <Label text="Embark on a journey where every corner of the world is within your reach."
                               textFill="#e2e8f0"
                               style="-fx-font-size: 16; -fx-font-family: 'Segoe UI';"
                               wrapText="true"/>
                    </children>
                </VBox>

                <VBox fx:id="mainForm"
                      alignment="TOP_LEFT"
                      spacing="13"
                      prefWidth="390"
                      maxWidth="390"
                      style="-fx-background-color: rgba(255,255,255,0.24); -fx-background-radius: 22; -fx-border-color: rgba(255,255,255,0.45); -fx-border-width: 1; -fx-border-radius: 22;">
                    <padding>
                        <Insets top="30" right="30" bottom="30" left="30"/>
                    </padding>
                    <effect>
                        <DropShadow color="rgba(15,23,42,0.45)" radius="28" offsetY="12"/>
                    </effect>

                    <children>
                        <Region prefHeight="8"/>

                        <HBox alignment="CENTER" prefHeight="82">
                            <children>
                                <StackPane fx:id="avatarPane" prefWidth="78" prefHeight="78" maxWidth="78" maxHeight="78">
                                    <children>
                                        <Circle radius="33" fill="rgba(255,255,255,0.92)" stroke="rgba(212,175,55,0.95)" strokeWidth="2.5"/>
                                        <HBox alignment="CENTER" spacing="12" translateY="-5">
                                            <children>
                                                <StackPane>
                                                    <children>
                                                        <Circle radius="8.5" fill="white"/>
                                                        <Circle fx:id="leftPupil" radius="3.3" fill="#1f2937"/>
                                                    </children>
                                                </StackPane>
                                                <StackPane>
                                                    <children>
                                                        <Circle radius="8.5" fill="white"/>
                                                        <Circle fx:id="rightPupil" radius="3.3" fill="#1f2937"/>
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER" spacing="18" translateY="-4">
                                            <children>
                                                <Circle fx:id="leftHand" radius="10.5" fill="#f2c9a5" opacity="0" translateY="-20"/>
                                                <Circle fx:id="rightHand" radius="10.5" fill="#f2c9a5" opacity="0" translateY="-20"/>
                                            </children>
                                        </HBox>
                                        <Label fx:id="avatarMouth" text="◡" translateY="17"
                                               style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                                    </children>
                                </StackPane>
                            </children>
                        </HBox>

                        <Label text="Email"
                               style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <TextField fx:id="emailField"
                                   promptText="Enter your email"
                                   prefHeight="44"
                                   style="-fx-font-size: 13; -fx-padding: 0 12 0 12; -fx-background-color: rgba(255,255,255,0.95); -fx-text-fill: #1f2937; -fx-border-color: transparent; -fx-border-radius: 7; -fx-background-radius: 7; -fx-font-family: 'Segoe UI';"/>

                        <Label text="Password"
                               style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <PasswordField fx:id="passwordField"
                                       promptText="••••••••••"
                                       prefHeight="44"
                                       style="-fx-font-size: 13; -fx-padding: 0 12 0 12; -fx-background-color: rgba(255,255,255,0.95); -fx-text-fill: #1f2937; -fx-border-color: transparent; -fx-border-radius: 7; -fx-background-radius: 7; -fx-font-family: 'Segoe UI';"/>

                        <HBox alignment="CENTER_LEFT" prefHeight="24" spacing="8">
                            <children>
                                <CheckBox fx:id="rememberCheckBox"
                                          text="Remember me"
                                          style="-fx-font-size: 11; -fx-text-fill: white;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Hyperlink fx:id="forgotLink"
                                           text="Forgot password?"
                                           style="-fx-font-size: 11; -fx-text-fill: white; -fx-underline: true; -fx-padding: 0;"/>
                            </children>
                        </HBox>

                        <Button fx:id="loginBtn"
                                text="SIGN IN"
                                prefHeight="44"
                                maxWidth="1.7976931348623157E308"
                                style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: linear-gradient(to right, #d4af37, #c9920f); -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 0; -fx-effect: dropshadow(gaussian, rgba(212, 175, 55, 0.4), 10, 0, 0, 5);"/>

                        <Button fx:id="googleLoginBtn"
                            text="CONTINUE WITH GOOGLE"
                            prefHeight="40"
                            maxWidth="1.7976931348623157E308"
                            style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-background-color: rgba(255,255,255,0.95); -fx-background-radius: 8; -fx-border-color: rgba(255,255,255,0.95); -fx-border-radius: 8; -fx-cursor: hand;"/>

                        <Button fx:id="faceLoginBtn"
                                text="SIGN IN WITH FACE ID"
                                prefHeight="40"
                                maxWidth="1.7976931348623157E308"
                                style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-background-color: rgba(255,255,255,0.9); -fx-background-radius: 7; -fx-border-color: rgba(255,255,255,0.95); -fx-border-radius: 7; -fx-cursor: hand;"/>

                        <HBox alignment="CENTER" spacing="4">
                            <children>
                                <Label text="Are you new?" style="-fx-font-size: 11; -fx-text-fill: white;"/>
                                <Hyperlink fx:id="signUpLink"
                                           text="Create an Account"
                                           style="-fx-font-size: 11; -fx-text-fill: white; -fx-underline: true; -fx-padding: 0;"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</StackPane>